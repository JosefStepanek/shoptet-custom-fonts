# Shoptet Partner API token (získáš v Partner adminu)
PARTNER_TOKEN=your_partner_token_here

# Základní URL tohoto doplňku (bez lomítka na konci)
BASE_URL=https://shoptet.josefstepanek.cz/custom-fonts

# Mock mode – true = funguje bez Shoptet Partner účtu (lokální vývoj)
MOCK_MODE=true

# Volitelné: Google Fonts API klíč (pro budoucí rozšíření full listingu)
# GOOGLE_FONTS_API_KEY=
