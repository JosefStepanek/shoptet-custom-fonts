# Shoptet Partner API token (obtain from Partner admin panel)
PARTNER_TOKEN=your_partner_token_here

# Base URL of this addon (no trailing slash)
BASE_URL=https://shoptet.josefstepanek.cz/custom-fonts

# Mock mode - set to true to run without a Shoptet Partner account (local dev)
MOCK_MODE=true

# Optional: Google Fonts API key (for future full font listing support)
# GOOGLE_FONTS_API_KEY=
